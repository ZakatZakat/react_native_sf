# CitySignal poller — secrets for the OFF-BOX machine.
# Copy to ".env" on the poller box and fill in. NEVER commit the real .env.
#
# These four come from your existing server .env (the Telegram creds you
# downloaded). They live ONLY here now, on a box you control.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_LOGIN_MODE=user
TELEGRAM_BOT_TOKEN=

# Mini-app bot token (only if you run the `bot` service here).
BOT_TELEGRAM_BOT_TOKEN=
# Where the bot's menu button opens the mini-app (your shared app server URL).
WEBAPP_URL=https://citysignal.digital-assistant.tech/cs/landing

# Public domain that points at THIS box (free options: DuckDNS, etc.).
# Caddy gets a Let's Encrypt cert for it automatically.
POLLER_DOMAIN=poller.example.duckdns.org

# Shared bearer token guarding the fetcher. Generate once:
#   openssl rand -hex 32
# Put the SAME value on the shared server as TELEGRAM_SERVICE_TOKEN.
INGEST_TOKEN=
